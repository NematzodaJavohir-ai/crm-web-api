@page "/groups"
@using BlazorApp.ApiServices.Interfaces
@using BlazorApp.DTOs.GroupDto
@using BlazorApp.DTOs.CourseDto
@using BlazorApp.DTOs.MentorDto
@using BlazorApp.DTOs.StudentDto
@inject IGroupApiService GroupService
@inject ICourseApiService CourseService
@inject IMentorApiService MentorService
@inject NavigationManager Navigation

<div class="students-page">

    <div class="page-header">
        <div class="page-header-left">
            <h1 class="page-title">Groups</h1>
            <span class="page-subtitle">Manage all groups in your platform</span>
        </div>
        <button class="btn-create" @onclick="OpenCreateModal">
            <i class="bi bi-plus-lg"></i>
            Add Group
        </button>
    </div>

    <div class="toolbar">
        <div class="search-wrap">
            <i class="bi bi-search"></i>
            <input type="text" placeholder="Search groups..."
                   @bind="searchQuery" @bind:event="oninput" />
        </div>
        <div class="filter-wrap">
            <select @bind="filterStatus">
                <option value="">All Status</option>
                <option value="Active">Active</option>
                <option value="Completed">Completed</option>
                <option value="Cancelled">Cancelled</option>
            </select>
        </div>
        <span class="total-count">@FilteredGroups.Count() groups</span>
    </div>

    @if (isLoading)
    {
        <div class="loading-wrap">
            <div class="spinner"></div>
            <span>Loading groups...</span>
        </div>
    }
    else if (!FilteredGroups.Any())
    {
        <div class="empty-state">
            <i class="bi bi-collection-play-fill"></i>
            <h3>No groups found</h3>
            <p>Try adjusting your search or add a new group</p>
            <button class="btn-create" @onclick="OpenCreateModal">
                <i class="bi bi-plus-lg"></i> Add First Group
            </button>
        </div>
    }
    else
    {
        <div class="groups-grid">
            @foreach (var group in FilteredGroups)
            {
                <div class="group-card">
                    <div class="group-card-header">
                        <div class="group-card-icon">
                            <i class="bi bi-collection-play-fill"></i>
                        </div>
                        <div class="group-card-status @(group.Status.ToString().ToLower())">
                            @group.Status
                        </div>
                    </div>
                    <div class="group-card-body">
                        <h3 class="group-card-title">@group.Name</h3>
                        <p class="group-card-description">@(group.Description ?? "No description")</p>
                        <div class="group-card-stats">
                            <div class="stat-item">
                                <i class="bi bi-book"></i>
                                <span>@group.Course?.Name</span>
                            </div>
                            <div class="stat-item">
                                <i class="bi bi-person-badge"></i>
                                <span>@group.Mentor?.FullName</span>
                            </div>
                            <div class="stat-item">
                                <i class="bi bi-people"></i>
                                <span>@group.CurrentStudentCount / @group.MaxStudents</span>
                            </div>
                            <div class="stat-item">
                                <i class="bi bi-calendar3"></i>
                                <span>@group.StartDate.ToString("dd.MM.yyyy")</span>
                            </div>
                        </div>
                    </div>
                    <div class="group-card-footer">
                        <button class="card-btn view" @onclick="() => OpenViewModal(group)">
                            <i class="bi bi-eye"></i> View
                        </button>
                        <button class="card-btn edit" @onclick="() => OpenEditModal(group)">
                            <i class="bi bi-pencil"></i> Edit
                        </button>
                        <button class="card-btn students" @onclick="() => GoToGroupStudents(group.Id)">
                            <i class="bi bi-people-fill"></i> Students
                        </button>
                        <button class="card-btn delete" @onclick="() => OpenDeleteConfirm(group)">
                            <i class="bi bi-trash3"></i>
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@* CREATE MODAL *@
@if (showCreateModal)
{
    <div class="modal-overlay" @onclick="CloseModals">
        <div class="premium-modal" @onclick:stopPropagation="true">
            <div class="premium-modal-header">
                <div class="premium-modal-icon create-icon">
                    <i class="bi bi-collection-play-fill"></i>
                </div>
                <div class="premium-modal-title-section">
                    <h2 class="premium-modal-title">Create New Group</h2>
                    <p class="premium-modal-subtitle">Fill in the information below</p>
                </div>
                <button class="premium-modal-close" @onclick="CloseModals">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="premium-modal-body">
                <div class="premium-form-grid">
                    <div class="premium-form-group full-width">
                        <label>Group Name <span class="required">*</span></label>
                        <div class="premium-input-wrapper">
                            <i class="bi bi-tag"></i>
                            <input type="text" @bind="createDto.Name" placeholder="e.g., Frontend Group A" />
                        </div>
                    </div>
                    <div class="premium-form-group">
                        <label>Course <span class="required">*</span></label>
                        <div class="premium-input-wrapper">
                            <i class="bi bi-book"></i>
                            <select @bind="createDto.CourseId">
                                <option value="0">Select Course</option>
                                @foreach (var course in courses)
                                {
                                    <option value="@course.Id">@course.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="premium-form-group">
                        <label>Mentor <span class="required">*</span></label>
                        <div class="premium-input-wrapper">
                            <i class="bi bi-person-badge"></i>
                            <select @bind="createDto.MentorId">
                                <option value="0">Select Mentor</option>
                                @foreach (var mentor in mentors)
                                {
                                    <option value="@mentor.Id">@mentor.FullName</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="premium-form-group">
                        <label>Start Date <span class="required">*</span></label>
                        <div class="premium-input-wrapper">
                            <i class="bi bi-calendar3"></i>
                            <input type="date" @bind="createDto.StartDate" />
                        </div>
                    </div>
                    <div class="premium-form-group">
                        <label>End Date</label>
                        <div class="premium-input-wrapper">
                            <i class="bi bi-calendar3"></i>
                            <input type="date" @bind="createDto.EndDate" />
                        </div>
                    </div>
                    <div class="premium-form-group">
                        <label>Max Students <span class="required">*</span></label>
                        <div class="premium-input-wrapper">
                            <i class="bi bi-people"></i>
                            <input type="number" @bind="createDto.MaxStudents" placeholder="15" />
                        </div>
                    </div>
                    <div class="premium-form-group full-width">
                        <label>Description</label>
                        <div class="premium-input-wrapper textarea">
                            <i class="bi bi-chat"></i>
                            <textarea @bind="createDto.Description" placeholder="Group description..." rows="3"></textarea>
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="premium-alert error">
                        <i class="bi bi-exclamation-circle-fill"></i>
                        @errorMessage
                    </div>
                }

                <div class="premium-modal-footer">
                    <button type="button" class="premium-btn-secondary" @onclick="CloseModals">Cancel</button>
                    <button type="button" class="premium-btn-primary" @onclick="CreateGroup" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="premium-spinner"></span>
                            <span>Creating...</span>
                        }
                        else
                        {
                            <i class="bi bi-check-lg"></i>
                            <span>Create Group</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* VIEW MODAL *@
@* VIEW MODAL *@
@if (showViewModal && selectedGroup != null)
{
    <div class="modal-overlay" @onclick="CloseModals">
        <div class="premium-modal premium-modal-view" @onclick:stopPropagation="true">
            <div class="premium-modal-header">
                <div class="premium-modal-icon view-icon">
                    <i class="bi bi-collection-play-fill"></i>
                </div>
                <div class="premium-modal-title-section">
                    <h2 class="premium-modal-title">Group Details</h2>
                    <p class="premium-modal-subtitle">View group information</p>
                </div>
                <button class="premium-modal-close" @onclick="CloseModals">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="premium-modal-body">
                <!-- Group Info -->
                <div class="profile-header-group">
                    <div class="profile-avatar-large group-color">
                        <i class="bi bi-collection-play-fill" style="font-size: 40px;"></i>
                    </div>
                    <div class="profile-info-large">
                        <h3 class="profile-name">@selectedGroup.Name</h3>
                        <span class="profile-email">@selectedGroup.Course?.Name</span>
                        <div class="profile-status-toggle">
                            <span class="status-label">Status:</span>
                            <div class="group-status-badge @(selectedGroup.Status.ToString().ToLower())">
                                @selectedGroup.Status
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Group Details -->
                <div class="details-grid">
                    <div class="detail-card clickable" @onclick="() => GoToMentor(selectedGroup.Mentor?.Id)">
                        <div class="detail-icon">
                            <i class="bi bi-person-badge"></i>
                        </div>
                        <div class="detail-content">
                            <label>Mentor</label>
                            <p>@(selectedGroup.Mentor?.FullName ?? "Not assigned")</p>
                        </div>
                    </div>

                    <div class="detail-card clickable" @onclick="() => GoToCourse(selectedGroup.Course?.Id)">
                        <div class="detail-icon">
                            <i class="bi bi-book"></i>
                        </div>
                        <div class="detail-content">
                            <label>Course</label>
                            <p>@(selectedGroup.Course?.Name ?? "Not assigned")</p>
                        </div>
                    </div>

                    <div class="detail-card">
                        <div class="detail-icon">
                            <i class="bi bi-calendar3"></i>
                        </div>
                        <div class="detail-content">
                            <label>Period</label>
                            <p>@selectedGroup.StartDate.ToString("dd MMM yyyy") - @(selectedGroup.EndDate?.ToString("dd MMM yyyy") ?? "Ongoing")</p>
                        </div>
                    </div>

                    <div class="detail-card">
                        <div class="detail-icon">
                            <i class="bi bi-calendar-check"></i>
                        </div>
                        <div class="detail-content">
                            <label>Created At</label>
                            <p>@selectedGroup.CreatedAt.ToString("dd MMM yyyy")</p>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(selectedGroup.Description))
                    {
                        <div class="detail-card full-width">
                            <div class="detail-icon">
                                <i class="bi bi-chat-quote"></i>
                            </div>
                            <div class="detail-content">
                                <label>Description</label>
                                <p class="bio-text">@selectedGroup.Description</p>
                            </div>
                        </div>
                    }
                </div>

                <!-- Students Section -->
                <div class="students-section">
                    <div class="students-section-header">
                        <h4><i class="bi bi-people-fill"></i> Students in this group</h4>
                        <span class="students-count">@(groupStudents?.Count ?? 0) / @selectedGroup.MaxStudents</span>
                    </div>
                    
                    @if (isLoadingStudents)
                    {
                        <div class="loading-small">
                            <div class="spinner-small"></div>
                            <span>Loading students...</span>
                        </div>
                    }
                    else if (groupStudents == null || !groupStudents.Any())
                    {
                        <div class="empty-students">
                            <i class="bi bi-person-x"></i>
                            <p>No students in this group yet</p>
                            <button class="btn-small" @onclick="() => GoToGroupStudents(selectedGroup.Id)">
                                <i class="bi bi-plus-lg"></i> Add Students
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="students-list">
                            @foreach (var student in groupStudents)
                            {
                                <div class="student-item">
                                    <div class="student-avatar-small">
                                        @GetInitials(student.FullName)
                                    </div>
                                    <div class="student-info">
                                        <div class="student-name">@student.FullName</div>
                                        <div class="student-details">
                                            <span><i class="bi bi-envelope"></i> @student.Email</span>
                                            <span><i class="bi bi-telephone"></i> @(student.Phone ?? "—")</span>
                                            <span><i class="bi bi-calendar-check"></i> Enrolled: @student.EnrollDate.ToString("dd.MM.yyyy")</span>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
            <div class="premium-modal-footer">
                <button class="premium-btn-secondary" @onclick="CloseModals">Close</button>
                <button class="premium-btn-edit" @onclick="(() => { CloseModals(); OpenEditModal(selectedGroup); })">
                    <i class="bi bi-pencil"></i> Edit Group
                </button>
                <button class="premium-btn-primary" @onclick="() => GoToGroupStudents(selectedGroup.Id)">
                    <i class="bi bi-people-fill"></i> Manage Students
                </button>
            </div>
        </div>
    </div>
}
@* DELETE MODAL *@
@if (showDeleteConfirm && selectedGroup != null)
{
    <div class="modal-overlay" @onclick="CloseModals">
        <div class="premium-modal premium-modal-sm" @onclick:stopPropagation="true">
            <div class="premium-modal-header">
                <div class="premium-modal-icon delete-icon">
                    <i class="bi bi-trash3-fill"></i>
                </div>
                <div class="premium-modal-title-section">
                    <h2 class="premium-modal-title">Delete Group</h2>
                    <p class="premium-modal-subtitle">This action cannot be undone</p>
                </div>
                <button class="premium-modal-close" @onclick="CloseModals">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="premium-modal-body text-center">
                <div class="delete-warning">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <p>Are you sure you want to delete <strong>@selectedGroup.Name</strong>?</p>
                    <small>All related data will be permanently removed.</small>
                </div>
            </div>
            <div class="premium-modal-footer">
                <button class="premium-btn-secondary" @onclick="CloseModals">Cancel</button>
                <button class="premium-btn-danger" @onclick="DeleteGroup" disabled="@isSaving">
                    @if (isSaving)
                    {
                        <span class="premium-spinner"></span>
                        <span>Deleting...</span>
                    }
                    else
                    {
                        <i class="bi bi-trash3"></i>
                        <span>Delete Permanently</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

@* EDIT MODAL *@
@if (showEditModal && selectedGroup != null)
{
    <div class="modal-overlay" @onclick="CloseModals">
        <div class="premium-modal" @onclick:stopPropagation="true">
            <div class="premium-modal-header">
                <div class="premium-modal-icon edit-icon">
                    <i class="bi bi-pencil-square"></i>
                </div>
                <div class="premium-modal-title-section">
                    <h2 class="premium-modal-title">Edit Group</h2>
                    <p class="premium-modal-subtitle">Update group information</p>
                </div>
                <button class="premium-modal-close" @onclick="CloseModals">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="premium-modal-body">
                <div class="premium-form-grid">
                    <div class="premium-form-group full-width">
                        <label>Group Name</label>
                        <div class="premium-input-wrapper">
                            <i class="bi bi-tag"></i>
                            <input type="text" @bind="selectedGroup.Name" />
                        </div>
                    </div>
                    <div class="premium-form-group">
                        <label>Mentor</label>
                        <div class="premium-input-wrapper">
                            <i class="bi bi-person-badge"></i>
                            <select @bind="editMentorId">
                                <option value="0">Select Mentor</option>
                                @foreach (var mentor in mentors)
                                {
                                    <option value="@mentor.Id">@mentor.FullName</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="premium-form-group">
                        <label>End Date</label>
                        <div class="premium-input-wrapper">
                            <i class="bi bi-calendar3"></i>
                            <input type="date" @bind="selectedGroup.EndDate" />
                        </div>
                    </div>
                    <div class="premium-form-group">
                        <label>Max Students</label>
                        <div class="premium-input-wrapper">
                            <i class="bi bi-people"></i>
                            <input type="number" @bind="selectedGroup.MaxStudents" />
                        </div>
                    </div>
                    <div class="premium-form-group">
                        <label>Status</label>
                        <div class="premium-input-wrapper">
                            <i class="bi bi-toggle-on"></i>
                            <select @bind="selectedGroup.Status">
                                <option value="Active">Active</option>
                                <option value="Completed">Completed</option>
                                <option value="Cancelled">Cancelled</option>
                            </select>
                        </div>
                    </div>
                    <div class="premium-form-group full-width">
                        <label>Description</label>
                        <div class="premium-input-wrapper textarea">
                            <i class="bi bi-chat"></i>
                            <textarea @bind="selectedGroup.Description" rows="3"></textarea>
                        </div>
                    </div>
                </div>

                <div class="premium-modal-footer">
                    <button type="button" class="premium-btn-secondary" @onclick="CloseModals">Cancel</button>
                    <button type="button" class="premium-btn-primary" @onclick="UpdateGroup" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="premium-spinner"></span>
                            <span>Saving...</span>
                        }
                        else
                        {
                            <i class="bi bi-save"></i>
                            <span>Save Changes</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<GroupResponseDto> groups = new();
    private List<CourseResponseDto> courses = new();
    private List<MentorShortDto> mentors = new();
    private List<StudentResponseDto>? groupStudents;
    private bool isLoading = true;
    private bool isSaving = false;
    private bool isLoadingStudents = false;
    private string searchQuery = "";
    private string filterStatus = "";
    private string errorMessage = "";
    private int editMentorId = 0;

    private bool showCreateModal = false;
    private bool showViewModal = false;
    private bool showEditModal = false;
    private bool showDeleteConfirm = false;

    private GroupCreateDto createDto = new();
    private GroupResponseDto? selectedGroup;

    private IEnumerable<GroupResponseDto> FilteredGroups =>
        groups.Where(g =>
            (string.IsNullOrEmpty(searchQuery) ||
             g.Name.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
             (g.Course?.Name?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false) ||
             (g.Mentor?.FullName?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false)) &&
            (string.IsNullOrEmpty(filterStatus) || g.Status.ToString() == filterStatus));

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            var groupsTask = GroupService.GetAllAsync();
            var coursesTask = CourseService.GetAllAsync();
            var mentorsTask = MentorService.GetAllShortAsync();

            await Task.WhenAll(groupsTask, coursesTask, mentorsTask);

            groups = groupsTask.Result ?? new();
            courses = coursesTask.Result ?? new();
            mentors = mentorsTask.Result ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadGroups()
    {
        isLoading = true;
        try
        {
            groups = await GroupService.GetAllAsync() ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading groups: {ex.Message}");
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadGroupStudents(int groupId)
{
    isLoadingStudents = true;
    StateHasChanged();
    
    try
    {
        var groupWithStudents = await GroupService.GetWithStudentsAsync(groupId);
        groupStudents = groupWithStudents?.Students?.ToList() ?? new List<StudentResponseDto>();
    }
    catch (Exception ex)
    {
        Console.WriteLine($"Error loading students: {ex.Message}");
        groupStudents = new List<StudentResponseDto>();
    }
    finally
    {
        isLoadingStudents = false;
        StateHasChanged();
    }
}
    private void OpenCreateModal()
    {
        createDto = new()
        {
            StartDate = DateTime.Today,
            MaxStudents = 15
        };
        errorMessage = "";
        showCreateModal = true;
    }

    private void OpenViewModal(GroupResponseDto group)
    {
        selectedGroup = group;
        showViewModal = true;
        _ = LoadGroupStudents(group.Id);
    }

    private void OpenEditModal(GroupResponseDto group)
    {
        selectedGroup = group;
        editMentorId = group.Mentor?.Id ?? 0;
        showEditModal = true;
    }

    private void OpenDeleteConfirm(GroupResponseDto group)
    {
        selectedGroup = group;
        showDeleteConfirm = true;
    }

    private void CloseModals()
    {
        showCreateModal = false;
        showViewModal = false;
        showEditModal = false;
        showDeleteConfirm = false;
        selectedGroup = null;
        groupStudents = null;
        errorMessage = "";
        editMentorId = 0;
        StateHasChanged();
    }

    private void GoToGroupStudents(int groupId)
    {
        Navigation.NavigateTo($"/groupstudents?groupId={groupId}");
    }

    private void GoToMentor(int? mentorId)
    {
        if (mentorId.HasValue && mentorId > 0)
        {
            Navigation.NavigateTo($"/mentors/{mentorId}");
        }
    }

    private void GoToCourse(int? courseId)
    {
        if (courseId.HasValue && courseId > 0)
        {
            Navigation.NavigateTo($"/courses/{courseId}");
        }
    }

    private async Task CreateGroup()
    {
        if (createDto.CourseId == 0)
        {
            errorMessage = "Please select a course";
            return;
        }
        if (createDto.MentorId == 0)
        {
            errorMessage = "Please select a mentor";
            return;
        }

        isSaving = true;
        errorMessage = "";
        StateHasChanged();

        try
        {
            var result = await GroupService.CreateAsync(createDto);
            if (result != null)
            {
                await LoadGroups();
                CloseModals();
            }
            else
            {
                errorMessage = "Failed to create group. Please try again.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            StateHasChanged();
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private async Task UpdateGroup()
    {
        if (selectedGroup == null) return;

        isSaving = true;
        errorMessage = "";
        StateHasChanged();

        try
        {
            var updateDto = new GroupUpdateDto
            {
                Name = selectedGroup.Name,
                MentorId = editMentorId,
                EndDate = selectedGroup.EndDate,
                MaxStudents = selectedGroup.MaxStudents,
                Description = selectedGroup.Description,
                Status = selectedGroup.Status
            };

            var result = await GroupService.UpdateAsync(selectedGroup.Id, updateDto);
            if (result != null)
            {
                await LoadGroups();
                CloseModals();
            }
            else
            {
                errorMessage = "Failed to update group. Please try again.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            StateHasChanged();
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private async Task DeleteGroup()
    {
        if (selectedGroup == null) return;

        isSaving = true;
        errorMessage = "";
        StateHasChanged();

        try
        {
            var success = await GroupService.DeleteAsync(selectedGroup.Id);
            if (success)
            {
                await LoadGroups();
                CloseModals();
            }
            else
            {
                errorMessage = "Failed to delete group. Please try again.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        return name.Length > 0 ? name[0].ToString().ToUpper() : "?";
    }
}