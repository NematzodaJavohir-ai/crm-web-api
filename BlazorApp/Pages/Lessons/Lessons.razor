@* ── VIDEO PLAYER MODAL ── *@
@if (showVideoModal && !string.IsNullOrEmpty(videoUrl))
{
    <div class="modal-overlay" @onclick="CloseVideoModal">
        <div class="video-modal" @onclick:stopPropagation="true">
            <div class="video-modal-header">
                <h3 class="video-modal-title">
                    <i class="bi bi-camera-video-fill"></i> Lesson Video
                </h3>
                <button class="video-modal-close" @onclick="CloseVideoModal">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="video-modal-body">
                <div class="video-container">
                    <iframe src="@GetVideoEmbedUrl(videoUrl)"
                            frameborder="0"
                            allowfullscreen
                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture">
                    </iframe>
                </div>
            </div>
        </div>
    </div>
}

@* ── PREMIUM DELETE MODAL ── *@
@if (showDeleteConfirm && selectedLesson != null)
{
    <div class="modal-overlay" @onclick="CloseModals">
        <div class="premium-modal premium-modal-sm" @onclick:stopPropagation="true">
            <div class="premium-modal-header">
                <div class="premium-modal-icon delete-icon">
                    <i class="bi bi-trash3-fill"></i>
                </div>
                <div class="premium-modal-title-section">
                    <h2 class="premium-modal-title">Delete Lesson</h2>
                    <p class="premium-modal-subtitle">This action cannot be undone</p>
                </div>
                <button class="premium-modal-close" @onclick="CloseModals">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="premium-modal-body text-center">
                <div class="delete-warning">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <p>Are you sure you want to delete <strong>@selectedLesson.Title</strong>?</p>
                    <small>All attendance records will be removed.</small>
                </div>
            </div>
            <div class="premium-modal-footer">
                <button class="premium-btn-secondary" @onclick="CloseModals">Cancel</button>
                <button class="premium-btn-danger" @onclick="DeleteLesson" disabled="@isSaving">
                    @if (isSaving)
                    {
                        <span class="premium-spinner"></span>
                        <span>Deleting...</span>
                    }
                    else
                    {
                        <i class="bi bi-trash3"></i>
                        <span>Delete Permanently</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

@code {
    
    private List<LessonResponseDto> lessons = new();
    private List<GroupResponseDto> allGroups = new();
    private int selectedGroupId = 0;
    private int selectedWeek = 0;
    private bool isLoading = true;
    private bool isSaving = false;
    private bool isEditing = false;
    private string searchQuery = "";
    private string errorMessage = "";
    private List<string> validationErrors = new();

    private bool showFormModal = false;
    private bool showDeleteConfirm = false;
    private bool showVideoModal = false;
    private string videoUrl = "";

    private LessonCreateDto createDto = new();
    private LessonResponseDto? selectedLesson;

    private IEnumerable<LessonResponseDto> FilteredLessons =>
        lessons.Where(l =>
            (selectedGroupId == 0 || l.GroupId == selectedGroupId) &&
            (selectedWeek == 0 || l.WeekNumber == selectedWeek) &&
            (string.IsNullOrEmpty(searchQuery) ||
             (l.Title?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false) ||
             l.GroupName.Contains(searchQuery, StringComparison.OrdinalIgnoreCase)));

    protected override async Task OnInitializedAsync()
    {
        allGroups = await GroupService.GetAllAsync() ?? new();
        await LoadLessons();
        isLoading = false;
    }

    private async Task OnGroupChanged()
    {
        selectedWeek = 0;
        await LoadLessons();
    }

    private async Task OnWeekChanged()
    {
        await LoadLessons();
    }

    private async Task LoadLessons()
    {
        isLoading = true;
        if (selectedGroupId > 0)
        {
            if (selectedWeek > 0)
                lessons = await LessonService.GetByWeekNumberAsync(selectedGroupId, selectedWeek) ?? new();
            else
                lessons = await LessonService.GetByGroupIdAsync(selectedGroupId) ?? new();
        }
        else
        {
            lessons = await LessonService.GetAllAsync() ?? new();
        }
        isLoading = false;
    }

    private void OpenCreateModal()
    {
        isEditing = false;
        createDto = new LessonCreateDto
        {
            GroupId = selectedGroupId > 0 ? selectedGroupId : 0,
            LessonDate = DateTime.Today,
            WeekNumber = selectedWeek > 0 ? selectedWeek : 1
        };
        errorMessage = "";
        validationErrors.Clear();
        showFormModal = true;
    }

    private void OpenEditModal(LessonResponseDto lesson)
    {
        isEditing = true;
        selectedLesson = lesson;
        createDto = new LessonCreateDto
        {
            GroupId = lesson.GroupId,
            WeekNumber = lesson.WeekNumber,
            LessonDate = lesson.LessonDate,
            Title = lesson.Title ?? "",
            Description = lesson.Description,
            HomeworkDescription = lesson.HomeworkDescription,
            MaterialUrl = lesson.MaterialUrl
        };
        errorMessage = "";
        validationErrors.Clear();
        showFormModal = true;
    }

    private void OpenDeleteConfirm(LessonResponseDto lesson)
    {
        selectedLesson = lesson;
        showDeleteConfirm = true;
    }

    private void OpenAttendance(int lessonId)
        => Navigation.NavigateTo($"/lessons/{lessonId}/attendance");

    private void WatchVideo(string url)
    {
        videoUrl = url;
        showVideoModal = true;
    }

    private void CloseVideoModal()
    {
        showVideoModal = false;
        videoUrl = "";
    }

    private void CloseModals()
    {
        showFormModal = false;
        showDeleteConfirm = false;
        selectedLesson = null;
        errorMessage = "";
        validationErrors.Clear();
    }

    private async Task SaveLesson()
    {
        isSaving = true;
        errorMessage = "";
        validationErrors.Clear();

        if (isEditing && selectedLesson != null)
        {
            var updateDto = new LessonUpdateDto
            {
                Title = createDto.Title,
                Description = createDto.Description,
                HomeworkDescription = createDto.HomeworkDescription,
                MaterialUrl = string.IsNullOrWhiteSpace(createDto.MaterialUrl) ? null : createDto.MaterialUrl
            };
            
            var result = await LessonService.UpdateAsync(selectedLesson.Id, updateDto);
            
            if (result != null)
            {
                await LoadLessons();
                CloseModals();
            }
            else
            {
                validationErrors = LessonService.LastErrors ?? new();
                if (!validationErrors.Any())
                    validationErrors.Add("Failed to update lesson. Please try again.");
            }
        }
        else
        {
            var result = await LessonService.CreateAsync(createDto);
            
            if (result != null)
            {
                await LoadLessons();
                CloseModals();
            }
            else
            {
                validationErrors = LessonService.LastErrors ?? new();
                if (!validationErrors.Any())
                    validationErrors.Add("Failed to create lesson. Please try again.");
            }
        }

        isSaving = false;
    }

    private async Task DeleteLesson()
    {
        if (selectedLesson == null) return;
        isSaving = true;
        var success = await LessonService.DeleteAsync(selectedLesson.Id);
        if (success)
        {
            await LoadLessons();
            CloseModals();
        }
        isSaving = false;
    }

    private async Task MarkComplete(int id)
    {
        await LessonService.MarkAsCompletedAsync(id);
        await LoadLessons();
    }

    private string GetVideoEmbedUrl(string url)
    {
        if (string.IsNullOrEmpty(url)) return "";
        
        // YouTube (watch?v=)
        if (url.Contains("youtube.com/watch?v="))
        {
            var videoId = url.Split("v=")[1].Split('&')[0];
            return $"https://www.youtube.com/embed/{videoId}";
        }
        // YouTube Shorts (youtu.be/)
        if (url.Contains("youtu.be/"))
        {
            var videoId = url.Split("youtu.be/")[1].Split('?')[0];
            return $"https://www.youtube.com/embed/{videoId}";
        }
        // Vimeo
        if (url.Contains("vimeo.com/"))
        {
            var videoId = url.Split("vimeo.com/")[1].Split('?')[0];
            return $"https://player.vimeo.com/video/{videoId}";
        }
        return url;
    }
}