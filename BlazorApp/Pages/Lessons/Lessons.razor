@page "/lessons"
@using BlazorApp.ApiServices.Interfaces
@using BlazorApp.DTOs.LessonDto
@using BlazorApp.DTOs.GroupDto
@inject ILessonApiService LessonService
@inject IGroupApiService GroupService
@inject NavigationManager Navigation

<div class="lessons-page">
    <div class="page-header">
        <div class="page-header-left">
            <div>
                <h1 class="page-title">Lessons</h1>
                <span class="page-subtitle">Manage lessons and track attendance</span>
            </div>
        </div>
        <button class="btn-create" @onclick="OpenCreateModal">
            <i class="bi bi-plus-lg"></i> Add Lesson
        </button>
    </div>

    <div class="filter-bar">
        <div class="form-group-inline">
            <label>Group</label>
            <select @bind="selectedGroupId" @bind:after="OnGroupChanged">
                <option value="0">-- All Groups --</option>
                @foreach (var g in allGroups)
                {
                    <option value="@g.Id">@g.Name</option>
                }
            </select>
        </div>
        @if (selectedGroupId > 0)
        {
            <div class="form-group-inline">
                <label>Week</label>
                <select @bind="selectedWeek" @bind:after="OnWeekChanged">
                    <option value="0">All Weeks</option>
                    @for (int w = 1; w <= 52; w++)
                    {
                        <option value="@w">Week @w</option>
                    }
                </select>
            </div>
        }
        <div class="search-wrap">
            <i class="bi bi-search"></i>
            <input type="text" placeholder="Search lessons..."
                   @bind="searchQuery" @bind:event="oninput" />
        </div>
        <span class="total-count">@FilteredLessons.Count() lessons</span>
    </div>

    @if (isLoading)
    {
        <div class="loading-wrap">
            <div class="spinner"></div>
            <span>Loading lessons...</span>
        </div>
    }
    else if (!FilteredLessons.Any())
    {
        <div class="empty-state">
            <i class="bi bi-calendar3"></i>
            <h3>No lessons found</h3>
            <p>Select a group or add a new lesson</p>
            <button class="btn-create" @onclick="OpenCreateModal">
                <i class="bi bi-plus-lg"></i> Add First Lesson
            </button>
        </div>
    }
    else
    {
        <div class="lessons-grid">
            @foreach (var lesson in FilteredLessons)
            {
                <div class="lesson-card @(lesson.IsCompleted ? "completed" : "")">
                    <div class="lesson-card-header">
                        <div class="lesson-week-badge">Week @lesson.WeekNumber</div>
                        @if (lesson.IsCompleted)
                        {
                            <span class="status-badge completed">
                                <i class="bi bi-check-circle-fill"></i> Completed
                            </span>
                        }
                        else
                        {
                            <span class="status-badge active">
                                <i class="bi bi-circle"></i> Upcoming
                            </span>
                        }
                    </div>

                    <div class="lesson-card-body">
                        <h3 class="lesson-title">@lesson.Title</h3>
                        <div class="lesson-meta">
                            <span class="meta-item">
                                <i class="bi bi-diagram-3"></i>
                                @lesson.GroupName
                            </span>
                            <span class="meta-item">
                                <i class="bi bi-calendar3"></i>
                                @lesson.LessonDate.ToString("dd MMM yyyy")
                            </span>
                        </div>
                        @if (!string.IsNullOrEmpty(lesson.Description))
                        {
                            <p class="lesson-desc">
                                @(lesson.Description.Length > 80
                                    ? lesson.Description[..80] + "..."
                                    : lesson.Description)
                            </p>
                        }
                        @if (!string.IsNullOrEmpty(lesson.HomeworkDescription))
                        {
                            <div class="homework-pill">
                                <i class="bi bi-journal-text"></i>
                                Homework assigned
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(lesson.MaterialUrl))
                        {
                            <button class="video-link" @onclick="() => WatchVideo(lesson.MaterialUrl)">
                                <i class="bi bi-play-circle-fill"></i>
                                Watch Lesson Video
                            </button>
                        }
                    </div>

                    <div class="lesson-card-footer">
                        <button class="btn-attendance" title="Open Attendance"
                                @onclick="() => OpenAttendance(lesson.Id)">
                            <i class="bi bi-check2-square"></i>
                            Attendance
                        </button>
                        <div class="card-actions">
                            <button class="btn-icon btn-edit" title="Edit"
                                    @onclick="() => OpenEditModal(lesson)">
                                <i class="bi bi-pencil"></i>
                            </button>
                            @if (!lesson.IsCompleted)
                            {
                                <button class="btn-icon btn-complete" title="Mark Complete"
                                        @onclick="() => MarkComplete(lesson.Id)">
                                    <i class="bi bi-check-lg"></i>
                                </button>
                            }
                            <button class="btn-icon btn-delete" title="Delete"
                                    @onclick="() => OpenDeleteConfirm(lesson)">
                                <i class="bi bi-trash3"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@* ── PREMIUM CREATE MODAL ── *@
@if (showFormModal && !isEditing)
{
    <div class="modal-overlay" @onclick="CloseModals">
        <div class="premium-modal" @onclick:stopPropagation="true">
            <div class="premium-modal-header">
                <div class="premium-modal-icon create-icon">
                    <i class="bi bi-calendar-plus-fill"></i>
                </div>
                <div class="premium-modal-title-section">
                    <h2 class="premium-modal-title">Add New Lesson</h2>
                    <p class="premium-modal-subtitle">Create a lesson for the group</p>
                </div>
                <button class="premium-modal-close" @onclick="CloseModals">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="premium-modal-body">
                <div class="premium-form-grid">
                    <div class="premium-form-group">
                        <label>Group <span class="required">*</span></label>
                        <div class="premium-input-wrapper">
                            <i class="bi bi-collection"></i>
                            <select @bind="createDto.GroupId">
                                <option value="0">-- Select group --</option>
                                @foreach (var g in allGroups)
                                {
                                    <option value="@g.Id">@g.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="premium-form-group">
                        <label>Week Number <span class="required">*</span></label>
                        <div class="premium-input-wrapper">
                            <i class="bi bi-grid"></i>
                            <input type="number" @bind="createDto.WeekNumber" min="1" max="52" />
                        </div>
                    </div>
                    <div class="premium-form-group">
                        <label>Lesson Date <span class="required">*</span></label>
                        <div class="premium-input-wrapper">
                            <i class="bi bi-calendar3"></i>
                            <input type="date" @bind="createDto.LessonDate" />
                        </div>
                    </div>
                    <div class="premium-form-group">
                        <label>Title <span class="required">*</span></label>
                        <div class="premium-input-wrapper">
                            <i class="bi bi-card-heading"></i>
                            <input type="text" @bind="createDto.Title" placeholder="Lesson title" />
                        </div>
                    </div>
                    <div class="premium-form-group full-width">
                        <label>Description</label>
                        <div class="premium-input-wrapper textarea">
                            <i class="bi bi-chat"></i>
                            <textarea @bind="createDto.Description" placeholder="Lesson description..." rows="3"></textarea>
                        </div>
                    </div>
                    <div class="premium-form-group full-width">
                        <label>Homework Description</label>
                        <div class="premium-input-wrapper textarea">
                            <i class="bi bi-journal-bookmark-fill"></i>
                            <textarea @bind="createDto.HomeworkDescription" placeholder="Homework details..." rows="2"></textarea>
                        </div>
                    </div>
                    <div class="premium-form-group full-width">
                        <label>Material URL (Video/Link)</label>
                        <div class="premium-input-wrapper">
                            <i class="bi bi-link-45deg"></i>
                            <input type="url" @bind="createDto.MaterialUrl" placeholder="https://..." />
                        </div>
                    </div>
                </div>

                @if (createDto.GroupId > 0)
                {
                    var selectedGroup = allGroups.FirstOrDefault(g => g.Id == createDto.GroupId);
                    if (selectedGroup != null)
                    {
                        <div class="info-hint">
                            <i class="bi bi-info-circle-fill"></i>
                            Group starts on <strong>@selectedGroup.StartDate.ToString("dd.MM.yyyy")</strong>
                        </div>
                    }
                }

                @* ── ОШИБКИ ВАЛИДАЦИИ ── *@
                @if (validationErrors.Any())
                {
                    <div class="validation-errors">
                        <div class="error-header">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                            <span>Validation failed:</span>
                        </div>
                        <ul class="error-list">
                            @foreach (var err in validationErrors)
                            {
                                <li>@err</li>
                            }
                        </ul>
                    </div>
                }

                <div class="premium-modal-footer">
                    <button class="premium-btn-secondary" @onclick="CloseModals">Cancel</button>
                    <button class="premium-btn-primary" @onclick="SaveLesson" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="premium-spinner"></span>
                            <span>Creating...</span>
                        }
                        else
                        {
                            <i class="bi bi-check-lg"></i>
                            <span>Create Lesson</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

